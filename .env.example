# === LINE ===
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# === Notion ===
NOTION_API_KEY=your_notion_integration_token_here
NOTION_DATABASE_ID=your_main_database_id_here
NOTION_DIGEST_DATABASE_ID=your_digest_database_id_here

# === AI (OpenRouter) ===
OPENROUTER_API_KEY=sk-or-v1-your_key_here
# 可選：覆蓋預設模型
# AI_MODEL_TEXT=deepseek/deepseek-v3.2-20251201
# AI_MODEL_VISION=google/gemini-3.1-flash-lite-preview-20260303
# AI_MODEL_AUDIO=google/gemini-3.1-flash-lite-preview-20260303
# AI_MODEL_COMPLEX=google/gemini-3-pro-preview

# === Processing ===
AGGREGATION_WINDOW_SECONDS=300
MIN_BATCH_SIZE=3
MAX_BATCH_SIZE=20
NOISE_FILTER_ENABLED=true
